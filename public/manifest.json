{
  "manifest_version": 3,
  "name": "AI Shopping List",
  "version": "1.0.0",
  "description": "A Chrome extension to let you keep track of products you're interested in by allowing you to add them to a local shopping list",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Open AI Shopping List",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}